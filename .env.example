# ============================================================================
# NERV-VIPER — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================================

# --- General ---
NERV_ENV=development
NERV_LOG_LEVEL=INFO
NEXT_PUBLIC_BACKEND_URL=https://your-backend-on-render.com

# --- API Keys ---
# OPENAI_API_KEY=sk-...
# GITHUB_TOKEN=ghp_...
# OLLAMA_HOST=http://localhost:11434

# --- Scan Configuration ---
NERV_SCAN_DEPTH=deep
NERV_OUTPUT_FORMAT=json
NERV_MAX_CLONE_TIMEOUT=120

# --- Report ---
NERV_REPORT_OUTPUT_DIR=./reports
