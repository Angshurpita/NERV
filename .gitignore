# ============================================================================
# NERV-VIPER Security Shield — .gitignore
# ============================================================================

# --- Environment & Secrets ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*
!.env.example
*.pem
*.key
*.cert
*.crt
*.pfx
*.p12
*.ssh
id_rsa*
secrets.*
*.db
*.sqlite

# --- Dependencies & Build ---
node_modules/
dist/
build/
.next/
out/
coverage/
.vercel
.netlify
*.tsbuildinfo

# --- Python ---
venv/
.venv/
__pycache__/
*.pyc
.pytest_cache/

# --- OS & System ---
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# --- IDEs & Editors ---
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# --- Application Specific ---
reports/
*.pdf
nerv_scan_*/
temp_*/
logs/
*.log
