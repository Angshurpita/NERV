# ============================================================================
# NERV-VIPER Web — .gitignore
# ============================================================================

# --- Dependencies ---
/node_modules
/.pnp
.pnp.*
/.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# --- Environment & Secrets ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.*
!.env.example

# --- Next.js & Build ---
/.next/
/out/
/build
/dist
/coverage
.vercel
.netlify
*.tsbuildinfo
next-env.d.ts

# --- OS & System ---
.DS_Store
Thumbs.db

# --- Debug ---
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
